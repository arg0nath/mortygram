  "fixed_sql": [
    {
      "name": "characters_table",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"characters_table\" (\"id\" INTEGER NOT NULL, \"page\" INTEGER NOT NULL, \"name\" TEXT NOT NULL, \"image\" TEXT NOT NULL, \"status\" TEXT NOT NULL, \"species\" TEXT NOT NULL, \"type\" TEXT NOT NULL, \"gender\" TEXT NOT NULL, \"episode\" TEXT NOT NULL, \"first_episode_name\" TEXT NULL, \"location\" TEXT NOT NULL, \"origin\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "character_details_table",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"character_details_table\" (\"id\" INTEGER NOT NULL, \"name\" TEXT NOT NULL, \"image\" TEXT NOT NULL, \"status\" TEXT NOT NULL, \"species\" TEXT NOT NULL, \"type\" TEXT NOT NULL, \"gender\" TEXT NOT NULL, \"episode\" TEXT NOT NULL, \"first_episode_name\" TEXT NULL, \"location\" TEXT NOT NULL, \"origin\" TEXT NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "pagination_metadata_table",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"pagination_metadata_table\" (\"endpoint\" TEXT NOT NULL, \"page\" INTEGER NOT NULL, \"count\" INTEGER NOT NULL, \"pages\" INTEGER NOT NULL, \"next\" TEXT NULL, \"prev\" TEXT NULL, \"last_synced\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), PRIMARY KEY (\"endpoint\", \"page\"));"
        }
      ]
    }
